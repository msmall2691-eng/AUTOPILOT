# Database - SQLite for dev, Postgres for production
# SQLite (development):
DATABASE_URL="file:./dev.db"
# Postgres (production):
# DATABASE_URL="postgresql://user:password@host:5432/autopilot?sslmode=require"

# Authentication
JWT_SECRET="change-me-to-a-random-64-character-string-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (optional - for payment processing)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Twilio (optional - for SMS/phone)
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+1..."

# Google Maps (optional - for dispatch map)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIza..."
